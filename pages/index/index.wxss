.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f5f5f5;
}

.logo {
  margin-bottom: 80rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.role-select {
  width: 80%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.role-btn {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.skill-btn {
  background-color: #e6f7ff;
}

.employer-btn {
  background-color: #f6ffed;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.skill-btn .btn-text {
  color: #1890ff;
}

.employer-btn .btn-text {
  color: #52c41a;
}

.btn-desc {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  padding: 0 20rpx;
}